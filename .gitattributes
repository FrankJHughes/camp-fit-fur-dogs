# Default — auto-normalize to LF in the repo, native on checkout
* text=auto

# Force LF for files that must have Unix line endings
*.sh text eol=lf
hooks/* text eol=lf
*.mjs text eol=lf
*.mts text eol=lf

# Windows batch files require CRLF to execute.
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary files — no conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary