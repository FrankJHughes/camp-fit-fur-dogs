# .env.example — Infrastructure connection parameters
# Copy to .env and customise as needed:  cp .env.example .env
# These values are interpolated by compose.yml at runtime.
# Defaults are baked into compose.yml, so .env is optional for standard local dev.

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=cffd
POSTGRES_PASSWORD=cffd_dev
POSTGRES_DB=campfitfurdogs
POSTGRES_PORT=5432
# Connection string (for appsettings.Development.json):
# Host=localhost;Port=5432;Database=campfitfurdogs;Username=cffd;Password=cffd_dev

# ── Redis ───────────────────────────────────────────────
REDIS_PORT=6379
# Connection string (for appsettings.Development.json):
# localhost:6379

# ── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=cffd
RABBITMQ_PASSWORD=cffd_dev
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
# Connection string (for appsettings.Development.json):
# amqp://cffd:cffd_dev@localhost:5672
# Management UI: http://localhost:15672
